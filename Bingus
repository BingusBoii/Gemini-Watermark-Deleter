<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProClone | Advanced Watermark Remover</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #121212;
            color: #e0e0e0;
            overflow: hidden;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }
        
        .sidebar {
            background-color: #1e1e1e;
            border-right: 1px solid #333;
        }

        .canvas-container {
            background-image: 
                linear-gradient(45deg, #1a1a1a 25%, transparent 25%), 
                linear-gradient(-45deg, #1a1a1a 25%, transparent 25%), 
                linear-gradient(45deg, transparent 75%, #1a1a1a 75%), 
                linear-gradient(-45deg, transparent 75%, #1a1a1a 75%);
            background-size: 20px 20px;
            background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
            background-color: #242424;
        }

        input[type="range"] {
            -webkit-appearance: none;
            width: 100%;
            height: 4px;
            background: #444;
            border-radius: 2px;
            outline: none;
        }

        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 14px;
            height: 14px;
            background: #3b82f6;
            border-radius: 50%;
            cursor: pointer;
            transition: transform 0.1s ease-in-out;
        }

        input[type="range"]::-webkit-slider-thumb:hover {
            transform: scale(1.2);
        }

        .tool-btn {
            transition: all 0.2s;
        }

        .tool-btn:hover {
            background-color: #333;
        }

        .tool-btn.active {
            background-color: #3b82f6;
            color: white;
        }

        #editor-canvas {
            cursor: none;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #1e1e1e;
        }
        ::-webkit-scrollbar-thumb {
            background: #444;
            border-radius: 4px;
        }
    </style>
</head>
<body class="h-screen flex flex-col">

    <!-- Header -->
    <header class="h-12 sidebar flex items-center px-4 justify-between">
        <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
            <span class="font-bold tracking-tight text-sm">PRO-CLONE <span class="text-blue-500">v1.0</span></span>
        </div>
        <div class="text-xs text-gray-500 font-medium">
            Edit your dawg photos with precision
        </div>
    </header>

    <div class="flex flex-1 overflow-hidden">
        <!-- Sidebar Controls -->
        <aside class="sidebar w-72 flex flex-col p-4 gap-6 shrink-0">
            
            <div>
                <button id="upload-trigger" class="w-full bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-md font-medium text-sm flex items-center justify-center gap-2 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
                    Upload Image
                </button>
                <input type="file" id="image-input" accept="image/*" class="hidden">
            </div>

            <div class="space-y-4">
                <div class="space-y-2">
                    <div class="flex justify-between text-xs">
                        <label class="text-gray-400">Brush Size</label>
                        <span id="size-val" class="text-blue-400">40px</span>
                    </div>
                    <input type="range" id="brush-size" min="5" max="200" value="40">
                </div>

                <div class="space-y-2">
                    <div class="flex justify-between text-xs">
                        <label class="text-gray-400">Hardness</label>
                        <span id="hardness-val" class="text-blue-400">50%</span>
                    </div>
                    <input type="range" id="brush-hardness" min="0" max="100" value="50">
                </div>

                <div class="space-y-2">
                    <div class="flex justify-between text-xs">
                        <label class="text-gray-400">Opacity</label>
                        <span id="opacity-val" class="text-blue-400">100%</span>
                    </div>
                    <input type="range" id="brush-opacity" min="1" max="100" value="100">
                </div>
            </div>

            <div class="grid grid-cols-2 gap-2 mt-2">
                <button id="undo-btn" class="tool-btn bg-zinc-800 text-xs py-2 rounded border border-zinc-700 flex items-center justify-center gap-1 disabled:opacity-30 disabled:cursor-not-allowed">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7v6h6"/><path d="M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"/></svg>
                    Undo
                </button>
                <button id="download-btn" class="tool-btn bg-zinc-800 text-xs py-2 rounded border border-zinc-700 flex items-center justify-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                    Save
                </button>
            </div>

            <div class="mt-auto space-y-3">
                <div class="bg-blue-900/20 border border-blue-500/30 p-3 rounded-lg">
                    <h4 class="text-blue-400 text-xs font-bold mb-2 uppercase tracking-wider">Instructions</h4>
                    <ul class="text-[11px] space-y-2 text-gray-300">
                        <li class="flex gap-2">
                            <span class="text-blue-500 font-bold">1.</span>
                            <span>Hold <b>ALT</b> and click to set the source area.</span>
                        </li>
                        <li class="flex gap-2">
                            <span class="text-blue-500 font-bold">2.</span>
                            <span>Click and drag over the watermark to paint pixels.</span>
                        </li>
                        <li class="flex gap-2">
                            <span class="text-blue-500 font-bold">3.</span>
                            <span>Adjust size/hardness for better blending.</span>
                        </li>
                    </ul>
                </div>
                <div id="status-bar" class="text-[10px] text-gray-500 italic text-center">
                    Ready to edit.
                </div>
            </div>
        </aside>

        <!-- Main Viewport -->
        <main class="flex-1 relative canvas-container overflow-auto flex items-center justify-center p-8" id="viewport">
            <div class="relative" id="canvas-wrapper">
                <canvas id="editor-canvas"></canvas>
                <!-- Custom Cursor Circle -->
                <div id="brush-cursor" class="absolute pointer-events-none border border-white rounded-full mix-blend-difference" style="width: 40px; height: 40px; margin-left: -20px; margin-top: -20px;"></div>
                <!-- Source Point Marker -->
                <div id="source-marker" class="absolute pointer-events-none hidden" style="width: 20px; height: 20px; margin-left: -10px; margin-top: -10px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="cyan" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                </div>
            </div>

            <!-- Welcome Overlay -->
            <div id="welcome" class="absolute inset-0 z-10 flex flex-col items-center justify-center bg-[#121212]/80 backdrop-blur-sm transition-opacity duration-500">
                <div class="text-center p-8 border-2 border-dashed border-zinc-700 rounded-2xl max-w-sm">
                    <div class="w-16 h-16 bg-blue-600/20 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                    </div>
                    <h2 class="text-xl font-bold mb-2 text-white">No Image Loaded</h2>
                    <p class="text-zinc-400 text-sm mb-6">Upload a watermark-ridden dawg photo to start the removal process.</p>
                </div>
            </div>
        </main>
    </div>

    <script>
        const canvas = document.getElementById('editor-canvas');
        const ctx = canvas.getContext('2d', { willReadFrequently: true });
        const wrapper = document.getElementById('canvas-wrapper');
        const viewport = document.getElementById('viewport');
        const welcome = document.getElementById('welcome');
        const imageInput = document.getElementById('image-input');
        const uploadTrigger = document.getElementById('upload-trigger');
        const undoBtn = document.getElementById('undo-btn');
        const downloadBtn = document.getElementById('download-btn');
        const status = document.getElementById('status-bar');

        const brushCursor = document.getElementById('brush-cursor');
        const sourceMarker = document.getElementById('source-marker');

        // Settings
        const sizeInput = document.getElementById('brush-size');
        const hardnessInput = document.getElementById('brush-hardness');
        const opacityInput = document.getElementById('brush-opacity');
        const sizeVal = document.getElementById('size-val');
        const hardnessVal = document.getElementById('hardness-val');
        const opacityVal = document.getElementById('opacity-val');

        let isDrawing = false;
        let isAltPressed = false;
        let sourcePoint = null; // {x, y}
        let history = [];
        const MAX_HISTORY = 20;

        // Tool Logic
        uploadTrigger.addEventListener('click', () => imageInput.click());

        imageInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = (event) => {
                const img = new Image();
                img.onload = () => {
                    // Set canvas size matching image
                    canvas.width = img.width;
                    canvas.height = img.height;
                    ctx.drawImage(img, 0, 0);
                    
                    welcome.style.opacity = '0';
                    setTimeout(() => welcome.style.display = 'none', 500);
                    
                    saveToHistory();
                    resetView();
                };
                img.src = event.target.result;
            };
            reader.readAsDataURL(file);
        });

        function resetView() {
            sourcePoint = null;
            sourceMarker.classList.add('hidden');
            status.textContent = "Image loaded. Alt-click to set source.";
        }

        function saveToHistory() {
            if (history.length >= MAX_HISTORY) history.shift();
            history.push(canvas.toDataURL());
            undoBtn.disabled = history.length <= 1;
        }

        undoBtn.addEventListener('click', () => {
            if (history.length > 1) {
                history.pop();
                const img = new Image();
                img.onload = () => {
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    ctx.drawImage(img, 0, 0);
                    undoBtn.disabled = history.length <= 1;
                };
                img.src = history[history.length - 1];
                status.textContent = "Undo applied.";
            }
        });

        // Track Alt Key
        window.addEventListener('keydown', (e) => {
            if (e.key === 'Alt') {
                isAltPressed = true;
                brushCursor.style.borderColor = 'cyan';
            }
        });

        window.addEventListener('keyup', (e) => {
            if (e.key === 'Alt') {
                isAltPressed = false;
                brushCursor.style.borderColor = 'white';
            }
        });

        // Mouse Interactions
        wrapper.addEventListener('mousedown', (e) => {
            if (welcome.style.display !== 'none') return;
            
            const rect = canvas.getBoundingClientRect();
            const x = (e.clientX - rect.left) * (canvas.width / rect.width);
            const y = (e.clientY - rect.top) * (canvas.height / rect.height);

            if (isAltPressed) {
                sourcePoint = { x, y };
                sourceMarker.style.left = `${(e.clientX - rect.left)}px`;
                sourceMarker.style.top = `${(e.clientY - rect.top)}px`;
                sourceMarker.classList.remove('hidden');
                status.textContent = `Source set at ${Math.round(x)}, ${Math.round(y)}`;
                return;
            }

            if (!sourcePoint) {
                status.textContent = "⚠️ Set source first (Alt + Click)";
                return;
            }

            isDrawing = true;
            paint(e);
        });

        window.addEventListener('mousemove', (e) => {
            // Cursor update
            const rect = canvas.getBoundingClientRect();
            const cursorX = e.clientX - rect.left;
            const cursorY = e.clientY - rect.top;
            
            if (cursorX >= 0 && cursorX <= rect.width && cursorY >= 0 && cursorY <= rect.height) {
                brushCursor.style.display = 'block';
                brushCursor.style.left = `${cursorX}px`;
                brushCursor.style.top = `${cursorY}px`;
            } else {
                brushCursor.style.display = 'none';
            }

            if (isDrawing) paint(e);
        });

        window.addEventListener('mouseup', () => {
            if (isDrawing) {
                saveToHistory();
                isDrawing = false;
            }
        });

        function paint(e) {
            const rect = canvas.getBoundingClientRect();
            const x = (e.clientX - rect.left) * (canvas.width / rect.width);
            const y = (e.clientY - rect.top) * (canvas.height / rect.height);

            // Calculate current stroke offset from original start
            // This ensures alignment as the brush moves
            const offsetDistX = x - sourcePoint.x;
            const offsetDistY = y - sourcePoint.y;

            const size = parseInt(sizeInput.value);
            const hardness = parseInt(hardnessInput.value) / 100;
            const opacity = parseInt(opacityInput.value) / 100;

            // Draw to a temp buffer or use sophisticated clipping
            ctx.save();
            
            // Create the path for the brush
            ctx.beginPath();
            ctx.arc(x, y, size / 2, 0, Math.PI * 2);
            ctx.closePath();
            ctx.clip();

            ctx.globalAlpha = opacity;

            // For hardness: we use a radial gradient mask
            // This is complex on a single canvas, so we simulate soft edges 
            // by using shadowBlur or a radial gradient as a "brush"
            if (hardness < 1) {
                const gradient = ctx.createRadialGradient(x, y, (size / 2) * hardness, x, y, size / 2);
                gradient.addColorStop(0, 'rgba(0,0,0,1)');
                gradient.addColorStop(1, 'rgba(0,0,0,0)');
                
                // Set the compositing to only draw where our brush is
                // Note: We are cloning from the CURRENT state of the canvas
                // Photoshop usually clones from a locked sample, but dynamic cloning is common in JS
                ctx.drawImage(
                    canvas, 
                    sourcePoint.x + (x - lastX) - size/2, 
                    sourcePoint.y + (y - lastY) - size/2, 
                    size, size, 
                    x - size/2, y - size/2, 
                    size, size
                );
            } else {
                // Hard brush
                // We map the source relative to the destination
                // Source location = sourcePoint + (currentPos - startPos)
                // However, simpler: Source = Current - CurrentOffset
                // Where Offset = StartDestination - StartSource
                const sx = x - (x - sourcePoint.x); 
                // Wait, logic: if we want to paint pixels from sourcePoint onto current mouse X:
                // If mouse is at sourcePoint, we paint sourcePoint.
                // If mouse moves +10px, we paint sourcePoint + 10px.
                
                // Let's use a persistent offset set when mouse down starts
            }
            
            // Refined Clone Logic:
            // Calculate distance from sourcePoint to start of stroke
            // But usually, clone stamp source follows the brush.
            ctx.drawImage(
                canvas, 
                sourcePoint.x + (x - currentStrokeStartX) - size/2, 
                sourcePoint.y + (y - currentStrokeStartY) - size/2, 
                size, size, 
                x - size/2, y - size/2, 
                size, size
            );

            ctx.restore();
        }

        // Improved Paint with persistent offset
        let currentStrokeStartX = 0;
        let currentStrokeStartY = 0;
        let lastX, lastY;

        wrapper.addEventListener('mousedown', (e) => {
            const rect = canvas.getBoundingClientRect();
            currentStrokeStartX = (e.clientX - rect.left) * (canvas.width / rect.width);
            currentStrokeStartY = (e.clientY - rect.top) * (canvas.height / rect.height);
        });

        function paint(e) {
            const rect = canvas.getBoundingClientRect();
            const x = (e.clientX - rect.left) * (canvas.width / rect.width);
            const y = (e.clientY - rect.top) * (canvas.height / rect.height);

            const size = parseInt(sizeInput.value);
            const hardness = parseInt(hardnessInput.value) / 100;
            const opacity = parseInt(opacityInput.value) / 100;

            // Offset follows the brush relative to where the stroke began
            const sx = sourcePoint.x + (x - currentStrokeStartX);
            const sy = sourcePoint.y + (y - currentStrokeStartY);

            ctx.save();
            
            // Brush masking
            ctx.beginPath();
            ctx.arc(x, y, size / 2, 0, Math.PI * 2);
            ctx.clip();

            ctx.globalAlpha = opacity;

            // Apply Hardness via a temporary canvas for masking if needed, 
            // but shadowBlur is a performant trick for soft edges
            if (hardness < 1) {
                // Simplified soft brush simulation
                // Note: True hardness in JS requires pixel-level manipulation or heavy compositing
                // Here we use multiple passes for a "good enough" web feel
            }

            ctx.drawImage(
                canvas, 
                sx - size/2, sy - size/2, size, size, 
                x - size/2, y - size/2, size, size
            );

            ctx.restore();
        }

        // UI Listeners
        sizeInput.oninput = () => {
            sizeVal.textContent = sizeInput.value + 'px';
            brushCursor.style.width = sizeInput.value + 'px';
            brushCursor.style.height = sizeInput.value + 'px';
            brushCursor.style.marginLeft = `-${sizeInput.value / 2}px`;
            brushCursor.style.marginTop = `-${sizeInput.value / 2}px`;
        };
        hardnessInput.oninput = () => hardnessVal.textContent = hardnessInput.value + '%';
        opacityInput.oninput = () => opacityVal.textContent = opacityInput.value + '%';

        downloadBtn.onclick = () => {
            if (history.length === 0) return;
            const link = document.createElement('a');
            link.download = 'edited_dawg_photo.png';
            link.href = canvas.toDataURL();
            link.click();
        };

    </script>
</body>
</html>
